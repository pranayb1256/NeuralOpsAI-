// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}


datasource db {
  provider = "postgresql"
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  name         String
  role         Role      @default(MEMBER)
  services     Service[] 
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

enum Role {
  ADMIN
  MEMBER
}

// --- 2. Core Infrastructure ---

model Service {
  id           String     @id @default(uuid())
  name         String     
  environment  String     @default("production")
  
  // High-performance API Key fields
  apiKeyPrefix String     @unique // e.g., "nop_7a3f9e"
  apiKeyHash   String     @unique // SHA-256 hash of the secret portion
  
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs         Log[]
  incidents    Incident[]
  createdAt    DateTime   @default(now())

  @@index([apiKeyPrefix]) // Critical for O(1) lookup speeds during log ingestion
}

// --- 3. Telemetry Data ---

model Log {
  id        String   @id @default(uuid())
  serviceId String
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  
  level     LogLevel
  message   String   @db.Text
  metadata  Json?    // JSONB in Postgres: Stores dynamic data like { "ip": "192...", "userId": "123" }
  
  // Vector embeddings will be handled in Python/pgvector later, but we keep the relation here
  embedding Unsupported("vector(384)")? // Placeholder for pgvector type
  timestamp DateTime @default(now())

  @@index([serviceId, timestamp]) // Composite index for ultra-fast time-series queries
}

enum LogLevel {
  INFO
  WARN
  ERROR
  FATAL
  DEBUG
}

// --- 4. AI & Observability ---

model Incident {
  id          String         @id @default(uuid())
  title       String
  status      IncidentStatus @default(OPEN)
  severity    Severity       @default(LOW)
  
  serviceId   String
  service     Service        @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  
  aiSummary   String?        @db.Text // Generated by our Python LangGraph agents
  rootCause   String?        @db.Text
  
  createdAt   DateTime       @default(now())
  resolvedAt  DateTime?

  @@index([serviceId, status])
}

enum IncidentStatus {
  OPEN
  INVESTIGATING
  RESOLVED
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}